# robot_server 运行环境变量示例
#
# 用法：
#   cp .env.example /etc/robot_factory/robot_server.env   # 真机部署
#   # 或本地调试
#   set -a && source .env.example && set +a
#
# 所有变量与 `robot_server/robot_server/config.py::load_config_from_env()` 一一对应。
# 未列出的变量按源码默认值走（见 README / docs/deploy.md）。
#
# ---------------------------------------------------------------------------
# 默认模式：robot_server 直接提供 BLE 服务
# ---------------------------------------------------------------------------
# 当前推荐链路：
#   * robot_server 同时负责 BLE / TCP / MQTT / ROS
#   * BLE 直接由 robot_server/transports/ble/bluez_gatt_glib.py 注册到 BlueZ
#   * 需要旁路调试时，再显式打开 TCP / MQTT
#
# 因此默认值保持为：
#   * ROBOT_BLE_ENABLED=true
#   * ROBOT_TCP_ENABLED=false
#   * ROBOT_MQTT_ENABLED=false

# ---------------------------------------------------------------------------
# 基础
# ---------------------------------------------------------------------------
# 机器狗唯一 ID（同时作为 MQTT topic 的 {id}，不得包含 / + #）
ROBOT_ID=dog-001

# 状态广播频率（Hz），遵循 AGENTS.md §4 的 10Hz 约定
ROBOT_STATE_HZ=10

# 调试态：周期性改动 battery / roll / pitch / yaw，便于验证手机 <- 机器狗
# 的 STATE 下行链路。默认关闭，正式部署保持 false。
ROBOT_DEBUG_STATE_TICK_ENABLED=false
ROBOT_DEBUG_STATE_TICK_SEC=1.0

# ---------------------------------------------------------------------------
# BLE（BlueZ GATT peripheral，默认开启）
# ---------------------------------------------------------------------------
ROBOT_BLE_ENABLED=true
ROBOT_BLE_ADAPTER=hci0
ROBOT_BLE_APP_PATH=/com/robotfactory/robotoslite
ROBOT_BLE_DEVICE_NAME=RobotOSLite-BLE
ROBOT_BLE_SERVICE_UUID=12345678-1234-5678-1234-56789abc0000
ROBOT_BLE_CMD_UUID=12345678-1234-5678-1234-56789abc0001
ROBOT_BLE_STATE_UUID=12345678-1234-5678-1234-56789abc0002
ROBOT_BLE_ADVERTISE_ENABLED=true
ROBOT_BLE_MTU_DEFAULT=23
ROBOT_BLE_MTU_MAX=517
# BLE D-Bus 后端选择：
#   auto       - 默认；Linux 真机优先 glib（dbus-python + GLib），否则 dbus_next
#   glib       - 强制 dbus-python + GLib MainLoop（aarch64 Ubuntu 20.04 首选）
#   dbus_next  - 强制 dbus-next / dbus-fast asyncio（x86 / CI 通常够用）
ROBOT_BLE_BACKEND=auto
# robot_server 启动时等待 bluetoothd + hci 适配器就绪的超时（秒）。
# 真机冷启动 bluetooth.service 常处于 activating 数十秒，建议 >=60。
ROBOT_BLE_READY_TIMEOUT_SEC=60

# ---------------------------------------------------------------------------
# TCP（默认关闭；需要旁路调试时再打开）
# ---------------------------------------------------------------------------
ROBOT_TCP_ENABLED=false
ROBOT_TCP_HOST=0.0.0.0
ROBOT_TCP_PORT=9000

# ---------------------------------------------------------------------------
# MQTT（默认关闭；上云 / 多路观测时再启用）
# ---------------------------------------------------------------------------
ROBOT_MQTT_ENABLED=false
ROBOT_MQTT_HOST=127.0.0.1
ROBOT_MQTT_PORT=1883
ROBOT_MQTT_QOS=1
# 留空则自动取 "robot-server-${ROBOT_ID}"
ROBOT_MQTT_CLIENT_ID=
# 鉴权，生产环境务必改为你自己的 broker 凭证；不使用鉴权时留空
ROBOT_MQTT_USERNAME=
ROBOT_MQTT_PASSWORD=
ROBOT_MQTT_KEEPALIVE=60
ROBOT_MQTT_TLS=false
ROBOT_MQTT_RECONNECT_MIN=1.0
ROBOT_MQTT_RECONNECT_MAX=30.0

# ---------------------------------------------------------------------------
# ROS1 控制下行（/cmd_vel @10Hz）
# ---------------------------------------------------------------------------
ROBOT_ROS_ENABLED=false
ROBOT_ROS_TOPIC=/cmd_vel
ROBOT_ROS_HZ=10.0
ROBOT_ROS_ENABLE_LATERAL=false
ROBOT_ROS_NODE=robot_os_lite

# ---------------------------------------------------------------------------
# ROS1 状态采集（battery / imu / odom / diagnostics）
# 详见 docs/ros_state_integration.md
# ---------------------------------------------------------------------------
ROBOT_ROS_STATE_ENABLED=false
ROBOT_ROS_BATTERY_TOPIC=/battery_state
ROBOT_ROS_BATTERY_MSG=sensor_msgs/BatteryState
ROBOT_ROS_IMU_TOPIC=/imu/data
ROBOT_ROS_IMU_MSG=sensor_msgs/Imu
ROBOT_ROS_ODOM_TOPIC=/odom
ROBOT_ROS_ODOM_MSG=nav_msgs/Odometry
ROBOT_ROS_DIAG_TOPIC=/diagnostics
ROBOT_ROS_DIAG_MSG=diagnostic_msgs/DiagnosticArray
ROBOT_ROS_BATTERY_LOW_PCT=20
ROBOT_ROS_BATTERY_EVENT_DEBOUNCE_SEC=60.0
ROBOT_ROS_QUEUE_SIZE=10
