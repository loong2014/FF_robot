# Optional visible name in BLE scan results.
ROBOT_BLE_LOCAL_NAME=RobotOSLite-BLE

# 128-bit UUIDs for the exposed custom GATT service and its characteristics.
ROBOT_BLE_SERVICE_UUID=7c2e0001-59d7-4b8b-9f3d-1bb8e31a0001
ROBOT_BLE_COMMAND_UUID=7c2e0001-59d7-4b8b-9f3d-1bb8e31a0002
ROBOT_BLE_STATUS_UUID=7c2e0001-59d7-4b8b-9f3d-1bb8e31a0003

# Optional hook. Leave empty to keep the BLE service fully standalone.
# To forward raw BLE writes into robot_server over loopback TCP, set:
# ROBOT_BLE_COMMAND_HOOK=/usr/bin/python3 /opt/robot_factory/scripts/robot_ble_to_tcp_hook.py
ROBOT_BLE_COMMAND_HOOK=

# Loopback bridge target for robot_ble_to_tcp_hook.py.
ROBOT_BLE_BRIDGE_HOST=127.0.0.1
ROBOT_BLE_BRIDGE_PORT=9000
ROBOT_BLE_BRIDGE_CONNECT_TIMEOUT_SEC=3
ROBOT_BLE_BRIDGE_READ_TIMEOUT_SEC=0.5

# Hook timeout and status payload size can be tuned if needed.
ROBOT_BLE_HOOK_TIMEOUT_SEC=5
ROBOT_BLE_STATUS_MAX_BYTES=240
ROBOT_BLE_LOG_LEVEL=INFO
